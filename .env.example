# Firebase client config — copy this file to .env.local and fill in the
# values from Firebase Console > Project settings > Your apps > Web app.
# .env.local is gitignored and never committed.
#
# Note: these are CLIENT identifiers, not secrets — they end up in the
# deployed JS bundle by design. Data security is enforced by
# firestore.rules (each user can only read/write their own documents).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
